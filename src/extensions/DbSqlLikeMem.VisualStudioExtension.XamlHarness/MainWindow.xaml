<Window x:Class="DbSqlLikeMem.VisualStudioExtension.XamlHarness.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DbSqlLikeMem VSIX XAML Harness"
        Height="760"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        DataContext="{Binding RelativeSource={RelativeSource Self}}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock VerticalAlignment="Center" Foreground="DimGray" Text="Use este app para validar se os XAML carregam fora do Visual Studio."/>
        </StackPanel>

        <Grid Grid.Row="1">
            <GroupBox Header="Tool Window Preview" Padding="8">
                <ContentControl x:Name="PreviewHost" />
            </GroupBox>

            <Border Background="#80FFFFFF"
                    Visibility="{Binding IsInitializing, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Width="280"
                        Padding="20"
                        Background="#F8FFFFFF"
                        CornerRadius="10">
                    <StackPanel HorizontalAlignment="Center">
                        <ProgressBar Width="240"
                                     Height="10"
                                     IsIndeterminate="True"
                                     Margin="0,0,0,12" />
                        <TextBlock Text="Carregando ambiente de teste..."
                                   TextAlignment="Center"
                                   TextWrapping="Wrap"
                                   FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Border>
        </Grid>
    </Grid>
</Window>
