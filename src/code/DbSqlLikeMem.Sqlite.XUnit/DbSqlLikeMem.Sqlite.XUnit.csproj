<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<Description>SQLite provider for the DbSqlLikeMem in-memory SQL-like database.</Description>
	</PropertyGroup>
	<ItemGroup>
	  <ProjectReference Include="..\DbSqlLikeMem.Sqlite\DbSqlLikeMem.Sqlite.csproj" />
	  <ProjectReference Include="..\DbSqlLikeMem.XUnit\DbSqlLikeMem.XUnit.csproj" />
	</ItemGroup>

	<ItemGroup Condition="'$(TargetFramework)' == 'net462'">
	  <PackageReference Include="SQLitePCLRaw.bundle_winsqlite3" Version="2.1.6" />
	</ItemGroup>

	<ItemGroup Condition="'$(TargetFramework)' == 'net6.0' Or '$(TargetFramework)' == 'net8.0'">
	  <PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" Version="2.1.6" />
	  <PackageReference Include="SQLitePCLRaw.lib.e_sqlite3" Version="2.1.6" />
	</ItemGroup>
</Project>
