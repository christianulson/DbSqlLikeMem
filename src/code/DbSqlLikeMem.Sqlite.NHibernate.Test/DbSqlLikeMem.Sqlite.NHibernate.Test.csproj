<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<IsPackable>false</IsPackable>
		<IsTestProject>true</IsTestProject>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\DbSqlLikeMem.NHibernate.TestTools\DbSqlLikeMem.NHibernate.TestTools.csproj" AdditionalProperties="TargetFramework=$(TargetFramework)" />
		<ProjectReference Include="..\DbSqlLikeMem.Sqlite.NHibernate\DbSqlLikeMem.Sqlite.NHibernate.csproj" AdditionalProperties="TargetFramework=$(TargetFrameworkFrom)" />
	</ItemGroup>

	<ItemGroup Condition="'$(TargetFramework)' == 'net462'">
		<PackageReference Include="SQLitePCLRaw.bundle_winsqlite3" Version="2.1.6" />
	</ItemGroup>

	<ItemGroup Condition="'$(TargetFramework)' == 'net6.0' Or '$(TargetFramework)' == 'net8.0'">
		<PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" Version="2.1.6" />
		<PackageReference Include="SQLitePCLRaw.lib.e_sqlite3" Version="2.1.6" />
	</ItemGroup>

	<ItemGroup>
		<Using Include="DbSqlLikeMem.Sqlite" />
		<Using Include="DbSqlLikeMem.NHibernate.TestTools" />
	</ItemGroup>

</Project>
