<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<Description>Oracle provider for the DbSqlLikeMem in-memory SQL-like database.</Description>
	</PropertyGroup>

	<ItemGroup Condition="'$(TargetFramework)' == 'net462'">
		<PackageReference Include="Oracle.ManagedDataAccess" Version="21.21.0" />
	</ItemGroup>

	<ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
		<PackageReference Include="Oracle.ManagedDataAccess.Core" Version="2.19.300" />
	</ItemGroup>

	<ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
		<PackageReference Include="Oracle.ManagedDataAccess.Core" Version="23.26.100" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\DbSqlLikeMem\DbSqlLikeMem.csproj" />
	</ItemGroup>
	<ItemGroup>
		<InternalsVisibleTo Include="DbSqlLikeMem.Oracle.NHibernate" />
		<InternalsVisibleTo Include="DbSqlLikeMem.Oracle.Test" />
		<InternalsVisibleTo Include="DbSqlLikeMem.Oracle.Dapper.Test" />
		<InternalsVisibleTo Include="DbSqlLikeMem.Oracle.NHibernate.Test" />
	</ItemGroup>
	<ItemGroup>
		<Using Include="DbSqlLikeMem.Resources" />
		<Using Include="System.Data" />
		<Using Include="System.Data.Common" />
		<Using Include="System.Globalization" />
		<Using Include="System.Text.RegularExpressions" />
	</ItemGroup>
</Project>
