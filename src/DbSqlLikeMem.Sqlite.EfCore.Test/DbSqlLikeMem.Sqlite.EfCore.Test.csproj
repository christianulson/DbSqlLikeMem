<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\DbSqlLikeMem.EfCore.TestTools\DbSqlLikeMem.EfCore.TestTools.csproj" AdditionalProperties="TargetFramework=$(TargetFramework)" />
    <ProjectReference Include="..\DbSqlLikeMem.Sqlite.TestTools\DbSqlLikeMem.Sqlite.TestTools.csproj" AdditionalProperties="TargetFramework=$(TargetFramework)" />
    <ProjectReference Include="..\DbSqlLikeMem.Sqlite.EfCore\DbSqlLikeMem.Sqlite.EfCore.csproj" AdditionalProperties="TargetFramework=$(TargetFrameworkFrom)" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net462'">
    <PackageReference Include="SQLitePCLRaw.bundle_winsqlite3" Version="2.1.6" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net6.0' Or '$(TargetFramework)' == 'net8.0'">
    <PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" Version="2.1.6" />
    <PackageReference Include="SQLitePCLRaw.lib.e_sqlite3" Version="2.1.6" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="DbSqlLikeMem.EfCore" />
    <Using Include="DbSqlLikeMem.EfCore.TestTools" />
    <Using Include="DbSqlLikeMem.Sqlite.TestTools" />
    <Using Include="DbSqlLikeMem.Sqlite.EfCore" />
  </ItemGroup>

</Project>
